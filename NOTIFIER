        local showcaseBrainrots = {}
        for _, b in ipairs(validBrainrots) do
            if b.value >= showcase.min and b.value <= showcase.max then
                table.insert(showcaseBrainrots, b)
            end
        end
        
        print("[SEND] ðŸ” " .. showcase.name .. " (" .. showcase.min .. "-" .. showcase.max .. "): " .. #showcaseBrainrots .. " matches")
        if #showcaseBrainrots > 0 then
            print("[SEND] ðŸ“¤ Sending " .. #showcaseBrainrots .. " to " .. showcase.name .. " (ASYNC)")
            local showcaseBest = showcaseBrainrots[1] or bestBrainrot
            sendToWebhookAsync(showcase.url, showcase.name, showcaseBrainrots, showcaseBest, false)
        end
    end
    
    print("[SEND] âœ… All webhooks queued (ASYNC)")
end

