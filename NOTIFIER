                end
                if isUltraR or r.value >= 1e9
                or isHighBrainrot(r.name)
                or isGodBrainrot(r.name)
                or isLuckyBlock(r.name)
                or (r.value >= 10e6 and not isEventBrainrot(r.name)) then
