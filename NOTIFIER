-- ROBUST HOP SYSTEM WITH MULTIPLE ATTEMPTS
-- =========================
local attemptedJobs = {}
local lastApiFetch = 0
local API_FETCH_COOLDOWN = 5 -- 5 seconds between API fetches

local function getPublicServers()
    local now = tick()
    if now - lastApiFetch < API_FETCH_COOLDOWN then
        print("[HOP] â±ï¸ API cooldown, waiting...")
        task.wait(API_FETCH_COOLDOWN - (now - lastApiFetch))
    end
    
    lastApiFetch = tick()
    local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Desc&excludeFullGames=false&limit=100"
    
    local result = makeRequest(url, "GET")
    
    if not result then
        print("[HOP] âŒ Failed to connect to API")
        return {}
    end
    
    local body = result.Body or result
    if not body or body == "" then
        print("[HOP] âš ï¸ API returned empty")
        return {}
    end
    
    local decode_ok, data = pcall(function()
        return HttpService:JSONDecode(body)
    end)
    
    if not decode_ok or not data or not data.data then
        print("[HOP] âŒ Failed to decode JSON")
        return {}
    end
    
    local servers = {}
    for _, server in ipairs(data.data) do
        if server.id ~= game.JobId and not attemptedJobs[server.id] then
            table.insert(servers, server.id)
        end
    end
    
    print("[HOP] âœ… Found " .. #servers .. " new servers")
    return servers
end

local function hopToRandomServer()
    print("[HOP] ðŸ” Fetching server list...")
    local servers = getPublicServers()
    
    if #servers == 0 then
        print("[HOP] âš ï¸ No servers available, waiting 2s before retry...")
        task.wait(2)
        attemptedJobs = {}
        return hopToRandomServer()
    end
    
    -- Try each server with aggressive attempts for 3 seconds
    for _, serverId in ipairs(servers) do
        print("[HOP] ðŸŽ¯ Trying server: " .. serverId:sub(1, 8) .. " (3 seconds of aggressive attempts)")
        
        local startTime = tick()
        local attemptCount = 0
        
        -- Spam teleport for 3 seconds with 1s attempts
        while tick() - startTime < 3 do
            pcall(function()
                TeleportService:TeleportToPlaceInstance(PLACE_ID, serverId, Player)
            end)
            attemptCount = attemptCount + 1
            task.wait(1)
        end
        
        -- Mark as attempted
        attemptedJobs[serverId] = true
        print("[HOP] ðŸ“ Server " .. serverId:sub(1, 8) .. " - " .. attemptCount .. " attempts in 3s, moving to next...")
        
        -- Small delay before next server
        task.wait(0.1)
    end
    
    print("[HOP] ðŸ”„ All servers attempted, clearing cache and retrying...")
    attemptedJobs = {}
    task.wait(1)
    return hopToRandomServer()
end

