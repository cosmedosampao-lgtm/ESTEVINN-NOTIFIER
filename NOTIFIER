local function getMutationEmojis(mutation)
    if not mutation or mutation == "" or mutation == "none" or mutation == "default" then return "" end
    local emojis = {}
    local low = mutation:lower()
    local found = false
    for key, emoji in pairs(MUTATION_EMOJIS) do
        if low:find(key, 1, true) then
            table.insert(emojis, emoji)
            found = true
        end
    end
    if not found then
        return "**[" .. mutation:upper() .. "]**"
    end
    -- Remove duplicatas
    local seen = {}
    local unique = {}
    for _, e in ipairs(emojis) do
        if not seen[e] then seen[e] = true table.insert(unique, e) end
    end
    return table.concat(unique, " ")
end

local function getBrainrotImage(name)
    local ok, result = pcall(function()
        local url = "https://stealabrainrot.fandom.com/api.php?action=query&titles="
                    .. HttpService:UrlEncode(name)
                    .. "&prop=pageimages&piprop=original&format=json"
        local resp = http_request({ Url = url, Method = "GET" })
        if resp and resp.StatusCode == 200 then
            local data = HttpService:JSONDecode(resp.Body)
            for _, page in pairs(data.query.pages) do
                if page.original and page.original.source then return page.original.source end
            end
        end
    end)
    return ok and result or nil
end

-- Emoji de raridade por valor
local function getRarityEmoji(value)
    if value >= 1e9  then return "🔶" end -- 1B+
    if value >= 500e6 then return "🟧" end -- 500M+
    if value >= 100e6 then return "🟦" end -- 100M+
    if value >= 50e6  then return "🟪" end -- 50M+
    if value >= 10e6  then return "🔹" end -- 10M+
    return "⬜"
end

-- Emojis de mutação inline de um brainrot
local function getInlineMutEmojis(mutation, traits)
    local allMuts = {}
    if mutation and mutation ~= "" and mutation ~= "none" and mutation ~= "default" then
        table.insert(allMuts, mutation)
    end
    if type(traits) == "table" then
        for _, t in ipairs(traits) do
            if type(t) == "string" and t ~= "" then table.insert(allMuts, t) end
        end
    end
    local emojis = {}
    local seen = {}
    for _, mut in ipairs(allMuts) do
        local low = mut:lower()
        for key, emoji in pairs(MUTATION_EMOJIS) do
            if low:find(key, 1, true) and not seen[emoji] then
                seen[emoji] = true
                table.insert(emojis, emoji)
            end
        end
    end
    return table.concat(emojis, " ")
end

local function getMutationPrefix(mutation)
    if not mutation then return "" end
    local m = mutation:lower()
    if m == "" or m == "none" or m == "default" then return "" end
    return "[" .. mutation:upper() .. "] "
end

-- Monta lista "Others" igual ao Goblin
local function buildListText(results, targetOwner, skipName)
    local lines = {}
    local count = 0
    for _, r in ipairs(results) do
        if r.name == skipName then continue end
        if count >= 20 then break end
        local rarityEmoji = getRarityEmoji(r.value)
        local mutEmojis   = getInlineMutEmojis(r.mutation, r.traits)
        local line = "1x " .. rarityEmoji .. " " .. r.name
        if mutEmojis ~= "" then line = line .. " " .. mutEmojis end
        line = line .. " ($" .. formatValue(r.value) .. "/s)"
        if r.inDuel then line = line .. " ⚔️" end
        table.insert(lines, line)
        count = count + 1
    end
    if #lines == 0 then return "" end
    return table.concat(lines, "\n")
end

local function sendWebhook(url, name, value, mutation, listText, showFields, footer, ownerName, jobId, includeJoinLink, inDuel, pingHere, traits)
    if not url or url == "" then return end

    local imageUrl   = getBrainrotImage(name)
    local joinLink   = "https://liphyrdev.github.io/notifier/?placeId=109983668079237&gameInstanceId=" .. (jobId or CURRENT_JOB)
    local mutPrefix  = getMutationPrefix(mutation)
    local channelLabel = CHANNEL_NAMES[footer] or footer or "Notifier"

    -- Junta mutation + traits para pegar todos os emojis
    local allMutations = {}
    if mutation and mutation ~= "" and mutation ~= "none" then
        table.insert(allMutations, mutation)
    end
    if type(traits) == "table" then
        for _, t in ipairs(traits) do
            if type(t) == "string" and t ~= "" then
                table.insert(allMutations, t)
            end
        end
    end

    -- Monta emojis de todas as mutações + traits
    local emojiSet = {}
    local emojiSeen = {}
    for _, mut in ipairs(allMutations) do
        local low = mut:lower()
        for key, emoji in pairs(MUTATION_EMOJIS) do
            if low:find(key, 1, true) and not emojiSeen[emoji] then
                emojiSeen[emoji] = true
                table.insert(emojiSet, emoji)
            end
        end
    end
    local mutEmojis = #emojiSet > 0 and table.concat(emojiSet, " ") or ""

    -- Se não achou emoji mas tem mutação, mostra o nome
    if mutEmojis == "" and #allMutations > 0 then
        local names = {}
        for _, m in ipairs(allMutations) do table.insert(names, "[" .. m:upper() .. "]") end
        mutEmojis = table.concat(names, " ")
    end

    -- Data/hora em Brasília completa
    local brasilia_time = os.date("!%d de %B de %Y às %H:%M", os.time() - 3 * 3600)

    local embedTitle = "Gaara Notifier | " .. channelLabel

    -- Emoji da mutação principal (Cyber, Gold, etc)
    local mainMutEmoji = ""
    if mutation and mutation ~= "" and mutation ~= "none" and mutation ~= "default" then
        local low = mutation:lower()
        for key, emoji in pairs(MUTATION_EMOJIS) do
            if low:find(key, 1, true) then
                mainMutEmoji = emoji
                break
            end
        end
        if mainMutEmoji == "" then mainMutEmoji = "**[" .. mutation:upper() .. "]**" end
    end

    -- Emojis dos traits (taco, fogo, etc) — linha separada
    local traitEmojis = {}
    local traitSeen = {}
    if type(traits) == "table" then
        for _, t in ipairs(traits) do
            if type(t) == "string" and t ~= "" then
                local low = t:lower()
                for key, emoji in pairs(MUTATION_EMOJIS) do
                    if low:find(key, 1, true) and not traitSeen[emoji] then
                        traitSeen[emoji] = true
                        table.insert(traitEmojis, emoji)
                    end
                end
            end
        end
    end
    local traitEmojisStr = table.concat(traitEmojis, " ")

    -- Linha do nome: emoji_mutação_principal [MUTAÇÃO] Nome $valor
    local nameDisplay = (mainMutEmoji ~= "" and mainMutEmoji .. " " or "") .. "**" .. mutPrefix .. name .. "** $" .. formatValue(value) .. "/s"

    local descParts = {}
    table.insert(descParts, nameDisplay)

    -- Traits em linha separada embaixo
    if traitEmojisStr ~= "" then
        table.insert(descParts, traitEmojisStr)
    end

    -- "Others" com lista dos outros brainrots
    if listText and listText ~= "" then
        table.insert(descParts, "\n**Others**\n" .. listText)
    end

    local description = table.concat(descParts, "\n")

    local fields = {}
    if includeJoinLink then
        table.insert(fields, {["name"] = "Owner                         Bot", ["value"] = "`" .. (ownerName or "?") .. "`          `" .. LocalPlayer.Name .. "`"})
        table.insert(fields, {["name"] = "Job ID",      ["value"] = "`" .. (jobId or CURRENT_JOB) .. "`"})
        table.insert(fields, {["name"] = "Server Info", ["value"] = "`" .. #Players:GetPlayers() .. "/8 Players`"})
        table.insert(fields, {["name"] = "Join Server", ["value"] = "[CLICK TO JOIN](" .. joinLink .. ")"})
    else
        table.insert(fields, {["name"] = "Owner                         Bot", ["value"] = "`" .. (ownerName or "?") .. "`          `" .. LocalPlayer.Name .. "`"})
        table.insert(fields, {["name"] = "Server Info", ["value"] = "`" .. #Players:GetPlayers() .. "/8 Players`"})
    end

    local embed = {
        ["title"]       = embedTitle,
        ["color"]       = 0,
        ["description"] = description,
        ["thumbnail"]   = { ["url"] = imageUrl or "" },
        ["fields"]      = fields,
        ["footer"]      = { ["text"] = "discord.gg/hFhE4QjHd | ✓ | " .. brasilia_time }
    }

    pcall(function()
        local body = { username = "Gaara Notifier", embeds = { embed } }
        if pingHere then body["content"] = "@here" end
        http_request({
            Url     = url,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode(body),
        })
    end)
end

-- Escaneia Lucky Blocks usando Synchronizer igual ao scanPlots
local function scanLuckyBlocks(seen, currentJobId)
    local results = {}
    if not Synchronizer then return results end

    local ok, plotsData = pcall(function() return Synchronizer:Get("Plots") end)
    if not ok or not plotsData then return results end

    for _, plotData in pairs(plotsData) do
        if type(plotData) ~= "table" then continue end
        local list = plotData.Animals or plotData.Brainrots or plotData.Items or {}
        if type(list) ~= "table" then continue end

        for _, animalData in pairs(list) do
            if type(animalData) ~= "table" then continue end
            local name = animalData.Index
            if not name then continue end

            -- Verifica se é Lucky Block da lista
            local isLucky = false
            for _, lb in ipairs(LUCKY_BLOCKS) do
                if lb ~= "" and name:lower() == lb:lower() then
                    isLucky = true
                    break
                end
            end
            if not isLucky then continue end

            local key = "lucky|" .. name:lower()
            if seen[key] then continue end
            seen[key] = true

            if hasBeenLogged(currentJobId, name, "lucky") then continue end

            table.insert(results, {
                name      = name,
                value     = 0,
                mutation  = nil,
                gen       = "Lucky Block",
                inDuel    = false,
                ownerName = "?",
                fromLucky = true,
            })
            print(string.format("🍀 LUCKY BLOCK: %s", name))
        end
    end

    return results
end
