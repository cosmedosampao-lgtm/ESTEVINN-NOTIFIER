-- =========================
local function cameBackFromDuel(player)
    if player == Player then
        local ok, data = pcall(function()
            return TeleportService:GetLocalPlayerTeleportData()
        end)
        if ok and type(data) == "table" then
            if data.fromDuel or data.DuelData or data.duel then return true end
        end
    end

    for _, child in ipairs(player:GetChildren()) do
        local nameLower = child.Name:lower()
        if nameLower:find("duel") or nameLower:find("returned") then
            return true
        end
    end

    local attrOk, attrs = pcall(function() return player:GetAttributes() end)
    if attrOk and attrs then
        for key, val in pairs(attrs) do
            if key:lower():find("duel") or key:lower():find("returned") then
                if val == true or val == 1 then return true end
            end
        end
    end

    return false
end

local function getPlotOwner(plot)
    local owner = plot:GetAttribute("Owner") or plot:GetAttribute("PlayerName") or plot.Name
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name == owner or tostring(player.UserId) == owner then
            return player
        end
    end
    return nil
end

local function getDuelPlayers()
    local duelPlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if cameBackFromDuel(player) then
            duelPlayers[player.Name] = true
            duelPlayers[tostring(player.UserId)] = true
        end
    end
    return duelPlayers
end

local function isPlotOwnerInDuel(plot, duelPlayers)
    local owner = plot:GetAttribute("Owner") or plot:GetAttribute("PlayerName") or plot.Name
    if duelPlayers[owner] or duelPlayers[tostring(owner)] then
        return true
    end
    local player = getPlotOwner(plot)
    if player and (duelPlayers[player.Name] or duelPlayers[tostring(player.UserId)]) then
        return true
    end
    return false
end

-- =========================
-- EXTRACT MUTATION AND TRAITS
-- =========================
local function extractMutation(animalData)
    if not animalData then return nil end
    local raw = animalData.Mutation or (animalData.Data and animalData.Data.Mutation)
    if type(raw) == "table" then
        raw = table.concat(raw, ", ")
    else
        raw = tostring(raw or "")
    end
    raw = raw:match("^%s*(.-)%s*$")
    if raw == "" or raw == "nil" then return "None" end
    return raw
end

local function extractTraits(animalData)
    local traits = {}
    local raw = animalData.Traits or (animalData.Data and animalData.Data.Traits)
    if type(raw) == "table" then
        for _, t in ipairs(raw) do table.insert(traits, t) end
    elseif type(raw) == "string" and raw ~= "" then
        table.insert(traits, raw)
    end
    return traits
end

-- =========================
-- PLOT SCANNER
-- =========================
local function scanBrainrots()
    local animals = {}
    local duelPlayers = getDuelPlayers()

    pcall(function()
        local Packages = game.ReplicatedStorage:FindFirstChild("Packages")
        local Datas = game.ReplicatedStorage:FindFirstChild("Datas")
        local Shared = game.ReplicatedStorage:FindFirstChild("Shared")

        if not Packages or not Datas or not Shared then return end

        local Synchronizer = require(Packages.Synchronizer)
        local AnimalsData = require(Datas.Animals)
        local AnimalsShared = require(Shared.Animals)

        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return end

        for _, plot in ipairs(plots:GetChildren()) do
            local channel = Synchronizer:Get(plot.Name)
            local animalList = channel and channel:Get("AnimalList")
            local owner = channel and channel:Get("Owner")

            if animalList then
                local ownerName = "Unknown"
                local ownerInDuel = isPlotOwnerInDuel(plot, duelPlayers)
                
                pcall(function()
                    if not owner then
                        ownerName = plot.Name:gsub("^Slot", ""):match("^%s*(.-)%s*$") or "Unknown"
                        return
                    end
                    
                    if type(owner) == "string" and owner ~= "" then
                        ownerName = owner
                    elseif type(owner) == "number" then
                        local player = game.Players:GetPlayerByUserId(owner)
                        if player then
                            ownerName = player.Name
                        else
                            ownerName = "ID: " .. tostring(owner)
                        end
                    elseif type(owner) == "table" then
                        if owner.Name and type(owner.Name) == "string" then
                            ownerName = owner.Name
                        elseif owner.DisplayName and type(owner.DisplayName) == "string" then
                            ownerName = owner.DisplayName
                        elseif owner.UserId then
                            local player = game.Players:GetPlayerByUserId(owner.UserId)
                            if player then
                                ownerName = player.Name
                            else
                                ownerName = "ID: " .. tostring(owner.UserId)
                            end
                        elseif owner.username and type(owner.username) == "string" then
                            ownerName = owner.username
                        else
                            for k, v in pairs(owner) do
                                if k == "Name" or k == "name" or k == "username" then
                                    ownerName = tostring(v)
                                    break
                                end
                            end
                        end
                    else
                        ownerName = tostring(owner) ~= "nil" and tostring(owner) or "Unknown"
                    end
                end)

                for _, data in pairs(animalList) do
                    local info = AnimalsData[data.Index]
                    if info then
                        local mutation = extractMutation(data)
                        local traits = extractTraits(data)

                        local ok, val = pcall(function()
                            return AnimalsShared:GetGeneration(data.Index, mutation, traits, nil)
                        end)

                        if ok and val >= MIN_VALUE then
                            local inFuse = false
                            if data.Machine and data.Machine.Type == "Fuse" and data.Machine.Active then
                                inFuse = true
                            elseif mutation and mutation:lower():find("fuse") then
                                inFuse = true
                            end
                            
                            local inDuel = isInDuel(data) or ownerInDuel

                            table.insert(animals, {
                                name = info.DisplayName or data.Index,
                                value = val,
                                genText = formatMoney(val),
                                mutation = mutation,
                                traits = traits,
                                inFuse = inFuse,
                                inDuel = inDuel,
                                data = data,
                                plotOwner = ownerName,
                            })
                        end
                    end
                end
            end
        end
    end)

    table.sort(animals, function(a, b) return a.value > b.value end)
    return animals
end

